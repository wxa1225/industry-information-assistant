# ============================================================
# 部署配置文件 - 部署到实验室服务器时填写
# ============================================================
# 使用方法：
# 1. 复制此文件为 .env：cp deploy.env .env
# 2. 填写真实的 API Key 和密码
# 3. 执行 docker compose up -d
# ============================================================

# ==================== 数据库 ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=industry_assistant

# ==================== Redis ====================
REDIS_PASSWORD=

# ==================== Milvus / MinIO ====================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ==================== LLM & Embedding ====================
# 阿里云百炼 API Key（必填）
DASHSCOPE_API_KEY=sk-你的百炼API密钥
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================== 搜索 API ====================
# 博查搜索 API（必填）
BOCHAAI_API_KEY=sk-你的博查API密钥

# Serper 搜索 API（可选）
SERPER_API_KEY=

# ==================== Tushare 财经数据（可选）====================
TUSHARE_API_KEY=

# ==================== RAGFlow 文档解析（可选）====================
RAGFLOW_API_KEY=
RAGFLOW_BASE_URL=http://localhost:8080

# ==================== JWT 认证 ====================
JWT_SECRET_KEY=你的JWT密钥-建议用随机字符串

# ==================== CORS 跨域 ====================
# 部署到服务器时，改成服务器的实际 IP 或域名
# 例如：CORS_ORIGINS=http://192.168.1.100:3000,http://你的域名:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ==================== 日志级别 ====================
LOG_LEVEL=INFO
