# ==========================================
# 行业信息助手 - 环境变量配置模板
# 复制为 .env 并填写真实值
# ==========================================

# === 数据库 ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<strong_password>
POSTGRES_DB=industry_assistant
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === Milvus ===
MILVUS_HOST=localhost
MILVUS_PORT=19530

# === 安全 ===
# 必须设置为强随机值！运行以下命令生成：
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# === CORS ===
# 生产环境必须设置为具体域名，逗号分隔
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# === LLM (阿里云 DashScope) ===
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# === 搜索 API ===
BOCHAAI_API_KEY=
SERPER_API_KEY=

# === 金融数据 API ===
TUSHARE_API_KEY=

# === RAGflow ===
RAGFLOW_API_KEY=
RAGFLOW_BASE_URL=http://localhost:8080

# === 应用配置 ===
# 开发模式：设为 true 自动创建数据库表
# 生产模式：设为 false，使用 Alembic 迁移
AUTO_MIGRATE=false

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# === 默认用户 ID ===
DEFAULT_USER_ID=anonymous
